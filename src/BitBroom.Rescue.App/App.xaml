<Application x:Class="BitBroom.Rescue.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:BitBroom.Rescue.App"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ui:ThemesDictionary Theme="Dark"/>
        <ui:ControlsDictionary/>
      </ResourceDictionary.MergedDictionaries>

      <!-- Brand accent shared with BitBroom. -->
      <SolidColorBrush x:Key="Brush.Accent" Color="#38BDF8"/>
      <SolidColorBrush x:Key="Brush.Good" Color="#34D399"/>
      <SolidColorBrush x:Key="Brush.Fair" Color="#FBBF24"/>
      <SolidColorBrush x:Key="Brush.Poor" Color="#F87171"/>
      <SolidColorBrush x:Key="Brush.Danger" Color="#F87171"/>

      <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
      <local:NullOrEmptyToVisibilityConverter x:Key="NullToVis"/>
    </ResourceDictionary>
  </Application.Resources>
</Application>
